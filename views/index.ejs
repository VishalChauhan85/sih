<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="<%= description %>">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <div class="role-selector-container">
        <div class="container">
            <div class="text-center mb-5">
                <div class="brand-logo">
                    <i class="fas fa-flask"></i>
                </div>
                <h1 class="brand-title">Streamwise Lab</h1>
                <p class="brand-subtitle">Your path to the right stream & college</p>
            </div>

            <div class="role-grid">
                <div class="role-card admin-card">
                    <div class="role-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h3>Admin</h3>
                    <p>Administrative access for school staff</p>
                    <a href="/login/admin" class="btn-role">Access Portal <i class="fas fa-arrow-right"></i></a>
                </div>

                <div class="role-card student10-card">
                    <div class="role-icon">
                        <i class="fas fa-graduation-cap"></i>
                    </div>
                    <h3>Class 10 Student</h3>
                    <p>Login portal for 10th grade students</p>
                    <a href="/login/student-10" class="btn-role">Access Portal <i class="fas fa-arrow-right"></i></a>
                </div>

                <div class="role-card student12-card">
                    <div class="role-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h3>Class 12 Student</h3>
                    <p>Login portal for 12th grade students</p>
                    <a href="/login/student-12" class="btn-role">Access Portal <i class="fas fa-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/script.js"></script>
</body>
</html>
