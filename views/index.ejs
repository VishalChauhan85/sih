<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="<%= description %>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    
    <div id="change" class="role-selector-container">
    <div class="container">
        <div class="text-center mb-5">
            <h1 class="display-4 text-white fw-bold mb-3">Streamwise Lab</h1>
            <p class="lead text-white-50">Choose your role to access the system</p>
        </div>
        
        <div class="row g-4">
            <div class="col-md-4">
                <div class="role-card admin-card" data-role="admin">
                    <div class="role-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h3>Admin Login</h3>
                    <p>Administrative access for school staff</p>
                    <a href="/login/admin" class="btn btn-role">Access Portal</a>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="role-card student10-card" data-role="student10">
                    <div class="role-icon">
                        <i class="fas fa-graduation-cap"></i>
                    </div>
                    <h3>Class 10 Student</h3>
                    <p>Login portal for 10th grade students</p>
                    <a href="/login/student-10" class="btn btn-role">Access Portal</a>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="role-card student12-card" data-role="student12">
                    <div class="role-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h3>Class 12 Student</h3>
                    <p>Login portal for 12th grade students</p>
                    <a href="/login/student-12" class="btn btn-role">Access Portal</a>
                </div>
            </div>
        </div>
    </div>
</div>


    
    <!-- <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script> -->
    <script src="/js/script.js"></script>
</body>
</html>




