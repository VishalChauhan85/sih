<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/colleges.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
</head>
<body>
    <header class="header">
        <div class="header-content">
            <a href="/dashboard" class="back-btn"><i class="fas fa-arrow-left"></i> Dashboard</a>
            <div class="logo"><i class="fas fa-flask"></i> Streamwise Lab</div>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i></a>
        </div>
    </header>

    <main class="colleges-container">
        <div class="page-hero">
            <h1><i class="fas fa-university"></i> Government College Finder</h1>
            <p>Find the best government colleges near you based on your profile and skills</p>
        </div>

        <!-- Filter Bar -->
        <div class="filter-bar">
            <div class="filter-group">
                <label><i class="fas fa-layer-group"></i> Stream</label>
                <select id="filterStream">
                    <option value="all">All Streams</option>
                    <option value="science">Science (PCM/PCB)</option>
                    <option value="commerce">Commerce</option>
                    <option value="arts">Arts / Humanities</option>
                    <option value="engineering">Engineering (B.Tech)</option>
                    <option value="medical">Medical (MBBS/BDS)</option>
                    <option value="law">Law (LLB)</option>
                    <option value="management">Management (BBA/MBA)</option>
                </select>
            </div>
            <div class="filter-group">
                <label><i class="fas fa-map"></i> State</label>
                <select id="filterState">
                    <option value="all">All States</option>
                    <option value="Delhi">Delhi</option>
                    <option value="Maharashtra">Maharashtra</option>
                    <option value="Karnataka">Karnataka</option>
                    <option value="Tamil Nadu">Tamil Nadu</option>
                    <option value="Uttar Pradesh">Uttar Pradesh</option>
                    <option value="Rajasthan">Rajasthan</option>
                    <option value="West Bengal">West Bengal</option>
                    <option value="Gujarat">Gujarat</option>
                    <option value="Punjab">Punjab</option>
                    <option value="Madhya Pradesh">Madhya Pradesh</option>
                    <option value="Bihar">Bihar</option>
                    <option value="Andhra Pradesh">Andhra Pradesh</option>
                    <option value="Kerala">Kerala</option>
                    <option value="Telangana">Telangana</option>
                    <option value="Haryana">Haryana</option>
                </select>
            </div>
            <div class="filter-group">
                <label><i class="fas fa-rupee-sign"></i> Annual Fees</label>
                <select id="filterFees">
                    <option value="all">Any Budget</option>
                    <option value="free">Free / Scholarship</option>
                    <option value="low">Under ₹10,000</option>
                    <option value="mid">₹10,000 – ₹50,000</option>
                    <option value="high">Above ₹50,000</option>
                </select>
            </div>
            <div class="filter-group">
                <label><i class="fas fa-search"></i> Search</label>
                <input type="text" id="searchInput" placeholder="Search college name...">
            </div>
            <button class="btn-filter" onclick="applyFilters()">
                <i class="fas fa-filter"></i> Apply
            </button>
            <button class="btn-reset" onclick="resetFilters()">
                <i class="fas fa-redo"></i> Reset
            </button>
        </div>

        <!-- Results Count -->
        <div class="results-meta">
            <span id="resultsCount">Showing <strong>24</strong> colleges</span>
            <% if (typeof assessment !== 'undefined' && assessment && assessment.state) { %>
                <span class="location-tag">
                    <i class="fas fa-map-marker-alt"></i> Near <%= assessment.state %>
                </span>
            <% } %>
        </div>

        <!-- College Cards Grid -->
        <div class="colleges-grid" id="collegesGrid">
            <!-- Cards are rendered by JS from data -->
        </div>

        <!-- No Results -->
        <div class="no-results" id="noResults" style="display:none;">
            <i class="fas fa-search"></i>
            <h3>No colleges found</h3>
            <p>Try changing your filters or search term</p>
            <button class="btn-filter" onclick="resetFilters()">Reset Filters</button>
        </div>
    </main>

    <script>
        // Pass server-side assessment data to JS
        const assessmentData = <%- JSON.stringify(typeof assessment !== 'undefined' ? assessment : {}) %>;
    </script>
    <script src="/js/colleges.js"></script>
</body>
</html>
